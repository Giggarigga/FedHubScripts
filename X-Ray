-- X-RAY LOGIC
local isEnabled = false
local originalTransparencies = {}

local function applyXray()
	for _, obj in pairs(Workspace:GetDescendants()) do
		if obj:IsA("BasePart") and not obj:IsDescendantOf(game.Players.LocalPlayer.Character) then
			-- Save original transparency if not already saved
			if not originalTransparencies[obj] then
				originalTransparencies[obj] = obj.Transparency
			end
			obj.Transparency = 0.5
		end
	end
end

local function removeXray()
	for obj, originalValue in pairs(originalTransparencies) do
		if obj and obj.Parent then
			obj.Transparency = originalValue
		end
	end
	originalTransparencies = {} -- Clear the table
end

ToggleBtn.MouseButton1Click:Connect(function()
	isEnabled = not isEnabled
	
	if isEnabled then
		-- Visual Feedback
		TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(255, 255, 255),
			TextColor3 = Color3.fromRGB(0, 0, 0)
		}):Play()
		
		applyXray()
	else
		-- Visual Feedback
		TweenService:Create(ToggleBtn, TweenInfo.new(0.2), {
			BackgroundColor3 = Color3.fromRGB(60, 60, 60),
			TextColor3 = Color3.fromRGB(255, 255, 255)
		}):Play()
		
		removeXray()
	end
end)
